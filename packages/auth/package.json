{
  "name": "@phub/auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./viva-delegation": {
      "types": "./src/viva-delegation.ts",
      "import": "./dist/viva-delegation.js"
    }
  },
  "scripts": {
